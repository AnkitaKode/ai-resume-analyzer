# Vercel Environment Variables Template
# Copy these to your Vercel project settings under Environment Variables

# Production API URL (required)
REACT_APP_API_URL=https://your-production-backend.com/api

# Optional: Add any other environment variables your app needs
# REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# REACT_APP_SENTRY_DSN=your-sentry-dsn
